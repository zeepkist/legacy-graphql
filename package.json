{
	"private": false,
	"name": "@zeepkist/graphql",
	"version": "0.0.0",
	"license": "MIT",
	"description": "GraphQL client for Zeepkists' GraphQL APIs",
	"author": "James Harris <wopian@wopian.me>",
	"homepage": "https://github.com/zeepkist/graphql#readme",
	"repository": "https://github.com/zeepkist/graphql",
	"bugs": {
		"url": "https://github.com/zeepkist/graphql/issues"
	},
	"funding": "https://github.com/sponsors/wopian",
	"type": "module",
	"main": "dist/index.js",
	"packageManager": "pnpm@10.14.0",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./schema": {
			"import": "./dist/gtr/schema.js",
			"require": "./dist/gtr/schema.js"
		},
		"./schema.graphql": {
			"import": "./dist/gtr/schema.graphql",
			"require": "./dist/gtr/schema.graphql"
		},
		"./types": {
			"import": "./dist/gtr/types.js",
			"require": "./dist/gtr/types.js"
		},
		"./runtime": {
			"import": "./dist/runtime/index.js",
			"require": "./dist/runtime/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"lint": "biome check --write",
		"lint:ci": "biome check",
		"test": "ava",
		"coverage": "c8 --all --src=dist --skip-full ava",
		"document": "typedoc",
		"generate:gtr": "genql --endpoint https://graphql.zeepki.st --language typescript --output src/gtr --clientName gtr",
		"publish:gtr": "rover subgraph publish zeepkist@current --schema src/gtr/schema.graphql --name GTR --routing-url https://graphql.zeepki.st",
		"publish-schemas": "pnpm publish:gtr",
		"move": "tsx scripts/moveRuntime.ts",
		"move:schema": "tsx scripts/moveSchema.ts",
		"generate": "pnpm generate:gtr && pnpm move",
		"start": "pnpm generate && pnpm document && pnpm lint"
	},
	"devDependencies": {
		"@apollo/rover": "^0.35.0",
		"@ava/typescript": "^5.0.0",
		"@biomejs/biome": "^1.9.4",
		"@genql/cli": "^6.3.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/github": "^11.0.1",
		"@semantic-release/npm": "^12.0.1",
		"@semantic-release/release-notes-generator": "^14.0.3",
		"@types/node": "^22.13.9",
		"ava": "^6.2.0",
		"c8": "^10.1.3",
		"conventional-changelog-conventionalcommits": "^9.0.0",
		"semantic-release": "^24.2.3",
		"tsx": "^4.19.3",
		"typedoc": "^0.28.0",
		"typescript": "^5.8.2"
	},
	"ava": {
		"utilizeParallelBuilds": true,
		"typescript": {
			"compile": "tsc",
			"rewritePaths": {
				"src/": "dist/"
			}
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@apollo/rover", "@biomejs/biome", "esbuild"]
	}
}
